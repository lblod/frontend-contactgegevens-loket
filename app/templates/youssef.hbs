{{page-title "youssef-test-form"}}
{{! Begin Form }}
{{!  RDF form example }}
<div class="au-c-body-container au-c-body-container--scroll">
  <div class="au-o-box au-o-flow au-o-flow--large">
    <RdfForm
  @groupClass="au-o-grid__item"
  @form={{@model.form}}
  @graphs={{@model.graphs}}
  @sourceNode={{@model.sourceNode}}
  @formStore={{@model.formStore}}
  @show={{false}}
  @forceShowErrors={{this.forceShowErrors}}
  @useNewListingLayout={{true}}
/>

<AuButton
  @skin="primary"
  @loading={{this.isLoading}}
  type="submit"
  {{on "click" (fn (perform this.saveTask this.model.site.id this.adminUnitId this.formData))}}>
Validate</AuButton>


  </div>
  </div>