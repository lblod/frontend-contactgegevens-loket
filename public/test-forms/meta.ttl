# Star rating concept scheme
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix uuid: <http://mu.semte.ch/vocabularies/core/uuid> .
@prefix rdf: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix order: <http://purl.org/linked-data/cube#order> .

# Foo bar baz example concept scheme
# foo, bar, baz, qux, quux, corge, grault // garply, waldo, fred, plugh, xyzzy, nacho, and thud;

<http://example-concept-schemes/concept-schemes/sitetypes>
    a <http://www.w3.org/2004/02/skos/core#ConceptScheme>;
    <http://www.w3.org/2004/02/skos/core#prefLabel> "Metasyntactic variables"@en.

<http://example-concept-schemes/concepts/foo>
    a skos:Concept, rdf:Class;
    skos:inScheme <http://example-concept-schemes/concept-schemes/sitetypes>;
    skos:prefLabel "Hoofdgebouw erediensten"@en;
    order: 1.

<http://example-concept-schemes/concepts/bar> 
    a skos:Concept, rdf:Class;
    skos:inScheme <http://example-concept-schemes/concept-schemes/sitetypes>;
    skos:prefLabel "Maatschappelijke zetel"@en;
    order: 2.

<http://example-concept-schemes/concepts/baz>
    a skos:Concept, rdf:Class;
    skos:inScheme <http://example-concept-schemes/concept-schemes/sitetypes>;
    skos:prefLabel "Districthuis"@en;
    order: 3.

<http://example-concept-schemes/concepts/qux>
    a skos:Concept, rdf:Class;
    skos:inScheme <http://example-concept-schemes/concept-schemes/sitetypes>;
    skos:prefLabel "Provinciehuis"@en;
    order: 4.

<http://example-concept-schemes/concepts/quux>
    a skos:Concept, rdf:Class;
    skos:inScheme <http://example-concept-schemes/concept-schemes/sitetypes>;
    skos:prefLabel "Ander administratief adres"@en;
    order: 5.

<http://example-concept-schemes/concepts/corge>
    a skos:Concept, rdf:Class;
    skos:inScheme <http://example-concept-schemes/concept-schemes/sitetypes>;
    skos:prefLabel "Gemeentehuis"@en;
    order: 6.

<http://example-concept-schemes/concepts/grault>
    a skos:Concept, rdf:Class;
    skos:inScheme <http://example-concept-schemes/concept-schemes/sitetypes>;
    skos:prefLabel "Andere vestiging"@en;
    order: 7.

