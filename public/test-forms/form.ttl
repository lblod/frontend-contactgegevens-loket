@prefix form: <http://lblod.data.gift/vocabularies/forms/> .
@prefix sh: <http://www.w3.org/ns/shacl#>.
@prefix mu: <http://mu.semte.ch/vocabularies/core/> .
@prefix fieldGroups: <http://data.lblod.info/field-groups/> .
@prefix fields: <http://data.lblod.info/fields/> .
@prefix displayTypes: <http://lblod.data.gift/display-types/> .
@prefix ext: <http://mu.semte.ch/vocabularies/ext/> .
@prefix schema: <http://schema.org/>.
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.

ext:mainFg a form:FieldGroup.

ext:form a form:Form;
    form:hasFieldGroup ext:mainFg.

ext:mainPg a form:PropertyGroup;
    sh:description "parent property-group, used to group fields and property-groups together";
    sh:name "Kerngegevens" ;
    sh:order 2 .

#Dropdown
ext:typeVestiging a form:Field ;
    sh:name "Type vestiging" ;
    sh:order 3 ;
    sh:path ext:conceptSchemeSelectorValue ;
    form:options """{"conceptScheme":"http://example-concept-schemes/concept-schemes/sitetypes","searchEnabled":false}""" ;
    form:displayType displayTypes:conceptSchemeSelector ;
    sh:group ext:mainPg .
ext:mainFg form:hasField ext:typeVestiging .






ext:mainPgCG a form:PropertyGroup;
    sh:description "parent property-group, used to group fields and property-groups together";
    sh:name "Contactgegevens" ;
    sh:order 700 .

ext:straat a form:Field ;
    sh:name "Straat" ;
    sh:order 2 ;  
    sh:path ext:StreetValue ;  
    form:displayType displayTypes:defaultInput ;  
      form:validations 
    [ a form:RequiredConstraint ;
      form:grouping form:Bag ;
      sh:path ext:StreetValue;
      sh:resultMessage "Vul een geldig adres in." ;
       ] ;
    sh:group ext:mainPgCG .  
ext:mainFg form:hasField ext:straat .

#Huisnummer
ext:huisnummer a form:Field ;
    sh:name "Huisnummer" ;
    sh:order 20 ;  
    sh:path ext:housenumberValue ;  
    form:displayType displayTypes:defaultInput ; 
      form:validations 
    [ a form:RequiredConstraint ;
      form:grouping form:Bag ;
      sh:path ext:housenumberValue;
      sh:resultMessage "Vul een geldig adres in." ;
       ] ;
    sh:group ext:mainPgCG .  
ext:mainFg form:hasField ext:huisnummer .

#Busnummer
ext:busnummer a form:Field ;
    sh:name "Busnummer" ;
    sh:order 30 ;  
    sh:path ext:newValue ;  
    form:displayType displayTypes:defaultInput ;  
    sh:group ext:mainPgCG .  
ext:mainFg form:hasField ext:busnummer .


#Postcode
ext:postcode a form:Field ;
    sh:name "Postcode" ;
    sh:order 40 ; 
    sh:path ext:postalcodeValue ;
    form:displayType displayTypes:defaultInput ;
         form:validations 
    [ a form:RequiredConstraint ;
      form:grouping form:Bag ;
      sh:path ext:postalcodeValue;
      sh:resultMessage "Vul een geldig adres in." ;
       ] ;
    sh:group ext:mainPgCG .  
ext:mainFg form:hasField ext:postcode .



#Gemeente
ext:gemeente a form:Field ;
    sh:name "Gemeente" ;
    sh:order 50 ; 
    sh:path ext:cityValue ;  
    form:displayType displayTypes:defaultInput ; 
    form:validations 
    [ a form:RequiredConstraint ;
      form:grouping form:Bag ;
      sh:path ext:cityValue;
      sh:resultMessage "Vul een geldig adres in." ;
       ] ;
    sh:group ext:mainPgCG .  
ext:mainFg form:hasField ext:gemeente .


#Provincie
ext:provincie a form:Field ;
    sh:name "Provincie" ;
    sh:order 60 ;  
    sh:path ext:munacipiltyValue ;  
    form:displayType displayTypes:defaultInput ;  
    form:validations 
    [ a form:RequiredConstraint ;
      form:grouping form:Bag ;
      sh:path ext:munacipiltyValue;
      sh:resultMessage "Vul een geldig adres in." ;
       ] ;
    sh:group ext:mainPgCG .  
ext:mainFg form:hasField ext:provincie .





ext:telefoonNummer a form:Field ;
    sh:name "Primaire telefoonnummer" ;
    sh:order 70 ;  
    sh:path ext:phonenumberValue ;  
    form:displayType displayTypes:defaultInput ;
    form:defaultCountry "BE";  
    form:validations 
    [ a form:constraintValidPhoneNumber ;
      form:grouping form:Bag ;
      sh:path ext:phonenumberValue;
      sh:resultMessage "Vul een geldig telefoonnumer in." ;
       ] ;
    sh:group ext:mainPgCG .  
ext:mainFg form:hasField ext:telefoonNummer .